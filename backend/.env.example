NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interviewer

# Required for the Interviewer Decision Engine (LLM orchestration).
# Groq has a free tier — get a key at https://console.groq.com/keys
GROQ_API_KEY=
DECISION_ENGINE_MODEL=openai/gpt-oss-120b
DECISION_ENGINE_REASONING_EFFORT=high

# Voice: speech-to-text (Whisper) and text-to-speech (PlayAI), also via Groq.
STT_MODEL=whisper-large-v3-turbo
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=troy
# canopylabs/orpheus-v1-english requires one-time org terms acceptance:
# https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english

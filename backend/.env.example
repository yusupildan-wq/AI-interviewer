NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interviewer

# Signs and encrypts auth session cookies. Required in production;
# defaults to an insecure dev value otherwise. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Required for the Interviewer Decision Engine and feedback generation.
# Groq has a free tier: https://console.groq.com/keys
GROQ_API_KEY=
DECISION_ENGINE_MODEL=openai/gpt-oss-20b
DECISION_ENGINE_REASONING_EFFORT=low

# Voice: speech-to-text via Groq, speech generation via OpenAI by default.
STT_MODEL=whisper-large-v3-turbo
VOICE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_INSTRUCTIONS=Speak like a calm, natural senior technical interviewer on a video call. Sound conversational, warm, and human. Use subtle pauses, natural pacing, and mild intonation. Do not sound like a narrator, announcer, or robot.

# Optional fallback if VOICE_PROVIDER=groq.
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=troy
